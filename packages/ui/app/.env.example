NUXT_PUBLIC_TITLE="OBSERVATIONS"

# Mainnet RPCs (artifact resolution) — space-separated list
NUXT_PUBLIC_EVM_CHAINS_MAINNET_RPCS=

# Sepolia RPCs (observations contract) — space-separated list
NUXT_PUBLIC_EVM_CHAINS_SEPOLIA_RPCS=

NUXT_PUBLIC_EVM_WALLET_CONNECT_PROJECT_ID=

NUXT_PUBLIC_OBSERVATIONS_CONTRACT=

# Observations indexer endpoints (used when mode=indexer, tried in order) — space-separated list
NUXT_PUBLIC_OBSERVATIONS_INDEXERS=

# Scope the app to a single artifact.
# When both are set, the root URL renders the artifact
# and deep links to other tokens are disabled.
NUXT_PUBLIC_CONTRACT=
NUXT_PUBLIC_TOKEN=
